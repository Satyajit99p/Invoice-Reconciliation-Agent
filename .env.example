# Invoice Reconciliation Agent - Unified Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# EXISTING SUPABASE CONFIGURATION (keep your existing values)
# ============================================================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
SUPABASE_DB_HOST=your_db_host_here
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=your_db_name_here
SUPABASE_DB_USER=your_db_user_here
SUPABASE_DB_PASSWORD=your_db_password_here

# ============================================================================
# CHAT INTERFACE CONFIGURATION (new settings)
# ============================================================================

# Backend API Settings
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
SESSION_TIMEOUT_HOURS=24

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# External Model APIs (optional - leave empty if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model Configuration
DEFAULT_MODEL=llama3.2
ENABLE_CLOUD_MODELS=false
MODEL_FALLBACK_ENABLED=true

# Logging
LOG_LEVEL=INFO

# Development Settings
GENERATE_SOURCEMAP=true
BROWSER=chrome

# ============================================================================
# EXISTING AGENT CONFIGURATION (if any - keep your existing values)
# ============================================================================

# Add any other existing environment variables you have here
# For example:
# CHROMA_API_KEY=your_chroma_api_key
# CHROMA_TENANT=your_chroma_tenant
# CHROMA_DATABASE=your_chroma_database
# BASE_URL=your_external_llm_base_url
# API_KEY=your_external_llm_api_key